	file = {フルテキスト:/Users/harukiyamamoto/Zotero/storage/8T9QFP5N/Vu et al. - 2023 - Estimating Hydrodynamic Coefficients of Real Ships Using AIS Data and Support Vector Regression.pdf:application/pdf},
}

