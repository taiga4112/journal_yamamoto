@article{statheros_autonomous_2008,
	title = {Autonomous {Ship} {Collision} {Avoidance} {Navigation} {Concepts}, {Technologies} and {Techniques}},
	volume = {61},
	copyright = {https://www.cambridge.org/core/terms},
