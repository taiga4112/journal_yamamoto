@article{li_risk_2023,
	title = {Risk and reliability analysis for maritime autonomous surface ship: {A} bibliometric review of literature from 2015 to 2022},
	volume = {187},
	issn = {0001-4575},
	shorttitle = {Risk and reliability analysis for maritime autonomous surface ship},
	url = {https://www.sciencedirect.com/science/article/pii/S0001457523001379},
	doi = {10.1016/j.aap.2023.107090},
	abstract = {Recently, researchers have shown a soaring interest in maritime autonomous surface ship (MASS). The reliable design and risk evaluation of MASS is crucial in order to support its safe operations. Hence, keeping abreast of emerging trends in developing MASSs safety and reliability-related technologies is necessary and significant. Nevertheless, a comprehensive literature review focused on this realm is currently lacking. On this premises, based on the 118 selected articles (consisting of 79 journal articles and 39 conference papers) between 2015 and 2022, content analyses and science mapping were conducted in this study from the aspects of journal sources, keywords, countries and institutions, authors, and citations of these publications. The bibliometric analysis aims to uncover several characteristics in this area such as the mainstream journals, research trends, knowledge contributors, and their cooperation relationships. Based on this, the research topic analysis was conducted from five facets including mechanical reliability and maintenance, software, hazard assessment, collision avoidance, communication and human element. It is suggested that the Model-Based System Engineering (MBSE) and Function Resonance Analysis Method (FRAM) could be two potential practical methods for future research risk and reliability analysis for MASS. This paper provides insights into the current state-of-the-art of risk and reliability research in MASS, including current research topics, gaps and future directions. It can also serve as a reference for related scholars.},
	urldate = {2026-03-19},
	journal = {Accident Analysis \& Prevention},
	author = {Li, Zhihong and Zhang, Di and Han, Bing and Wan, Chengpeng},
	month = jul,
	year = {2023},
	keywords = {Literature review, MASS, Risk and reliability analysis, Science mapping, Scientometric analysis},
	pages = {107090},
	file = {ScienceDirect Full Text PDF:/Users/harukiyamamoto/Zotero/storage/W6G9S87E/Li et al. - 2023 - Risk and reliability analysis for maritime autonomous surface ship A bibliometric review of literat.pdf:application/pdf;ScienceDirect Snapshot:/Users/harukiyamamoto/Zotero/storage/ZDJEY3XL/S0001457523001379.html:text/html},
}

